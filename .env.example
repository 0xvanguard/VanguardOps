# =====================================================================
# VanguardOps - Example environment configuration
# Copy to `.env` and adjust values. NEVER commit a real `.env` file.
# =====================================================================

# --- Application ---
ENVIRONMENT=development           # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                   # json | console

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Bootstrap admin (created on first startup if no users exist) ---
BOOTSTRAP_ADMIN_EMAIL=admin@vanguardops.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!2024

# --- Database ---
DATABASE_URL=postgresql+psycopg2://user:password@db:5432/vanguardops

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- CORS (comma-separated list of origins) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Rate limiting ---
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute

# --- Flower (Celery monitor) ---
FLOWER_BASIC_AUTH=admin:ChangeMe!2024
